# 生产环境必须改。可以用下面命令生成：
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# 可选，默认 data/app.sqlite3
MCFINDER_DB=

# 可选：native/cubiomes 查询并行度。默认 min(8, CPU 核心数 - 1)
MC_QUERY_WORKERS=

# 可选：每个 native batch subprocess 承载的查询数。默认 64，范围 1-512
MC_QUERY_BATCH_SIZE=

# 持久搜索任务 worker 数量、完成任务保留天数
SEARCH_JOB_WORKERS=1
SEARCH_JOB_RETENTION_DAYS=30

# 持久地图缓存（默认 data/map-cache，默认上限 2 GiB）
MCFINDER_MAP_CACHE_DIR=
MCFINDER_MAP_CACHE_MAX_AGE_DAYS=30
MCFINDER_MAP_CACHE_MAX_BYTES=2147483648

# 可选：夜间聚类后调用 Codex。默认关闭，且只生成待审核 patch，不自动部署。
EVOLUTION_CODEX_ENABLED=0
EVOLUTION_CODEX_BIN=codex
EVOLUTION_CODEX_TIMEOUT_SECONDS=1800
